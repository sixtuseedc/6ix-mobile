// src/screens/ChatCallScreen.js
import React, { useEffect, useRef, useState } from "react";
import {
  View,
  Text,
  FlatList,
  TextInput,
  Pressable,
  StyleSheet,
  KeyboardAvoidingView,
  Platform,
} from "react-native";
import { useAppTheme } from "../context/AppContext";
import {
  getMessagesForThread,
  saveOutboundMessage,
  saveCallLog,
  subscribeToMessages,
} from "../api/supabase";
import { sendSms, startCall, hangupCall, muteCall } from "../api/telnyx";
import { spacing, radius, typography } from "../constants/theme";
import Header from "../components/Header";
import { formatPhoneNumber, formatCallDuration } from "../utils/formatters";

const DIAL_KEYS = [
  ["1", "2", "3"],
  ["4", "5", "6"],
  ["7", "8", "9"],
  ["*", "0", "#"],
];

export default function ChatCallScreen({ route, navigation }) {
  const { threadId, contactNumber, numberId } = route.params || {};
  const { colors, activeNumber } = useAppTheme();

  const [view, setView] = useState("chat"); // "chat" | "dialer"
  const [messages, setMessages] = useState([]);
  const [draft, setDraft] = useState("");
  const [sending, setSending] = useState(false);
  const listRef = useRef(null);

  const [dialedNumber, setDialedNumber] = useState(contactNumber || "");
  const [callState, setCallState] = useState("idle"); // idle | dialing | active | ended
  const [callControlId, setCallControlId] = useState(null);
  const [muted, setMuted] = useState(false);
  const [speaker, setSpeaker] = useState(false);
  const [callSeconds, setCallSeconds] = useState(0);
  const callTimerRef = useRef(null);

  useEffect(() => {
    let unsubscribe;
    if (threadId) {
      getMessagesForThread(threadId)
        .then(setMessages)
        .catch(() => setMessages([]));

      if (numberId) {
        unsubscribe = subscribeToMessages(numberId, (msg) => {
          if (msg.thread_id === threadId) {
            setMessages((prev) => [...prev, msg]);
          }
        });
      }
    }
    return () => unsubscribe?.();
  }, [threadId, numberId]);

  useEffect(() => {
    if (callState === "active") {
      callTimerRef.current = setInterval(() => setCallSeconds((s) => s + 1), 1000);
    } else {
      clearInterval(callTimerRef.current);
      if (callState === "idle") setCallSeconds(0);
    }
    return () => clearInterval(callTimerRef.current);
  }, [callState]);

  async function handleSend() {
    if (!draft.trim() || !activeNumber) return;
    setSending(true);
    const body = draft.trim();
    setDraft("");
    try {
      const result = await sendSms({
        from: activeNumber.phone_number,
        to: contactNumber,
        text: body,
      });
      const saved = await saveOutboundMessage({
        threadId,
        numberId: activeNumber.id,
        toNumber: contactNumber,
        body,
        telnyxMessageId: result.telnyxMessageId,
      });
      setMessages((prev) => [...prev, saved]);
      requestAnimationFrame(() => listRef.current?.scrollToEnd({ animated: true }));
    } catch {
      // Keep the draft so the user doesn't lose their text on failure.
      setDraft(body);
    } finally {
      setSending(false);
    }
  }

  function handleDialPress(key) {
    setDialedNumber((prev) => prev + key);
  }

  function handleBackspace() {
    setDialedNumber((prev) => prev.slice(0, -1));
  }

  async function handleCallPress() {
    if (!activeNumber || !dialedNumber) return;
    setCallState("dialing");
    try {
      const { callControlId: id } = await startCall({
        from: activeNumber.phone_number,
        to: dialedNumber,
      });
      setCallControlId(id);
      setCallState("active");
    } catch {
      setCallState("idle");
    }
  }

  async function handleEndCall() {
    const duration = callSeconds;
    try {
      if (callControlId) await hangupCall(callControlId);
    } catch {
      // best-effort — still log locally
    }
    if (activeNumber) {
      saveCallLog({
        numberId: activeNumber.id,
        toNumber: dialedNumber,
        direction: "outbound",
        status: "completed",
        telnyxCallControlId: callControlId,
        durationSeconds: duration,
      }).catch(() => {});
    }
    setCallState("idle");
    setCallControlId(null);
    setMuted(false);
  }

  async function handleToggleMute() {
    if (!callControlId) return;
    try {
      await muteCall(callControlId, muted);
      setMuted((m) => !m);
    } catch {
      // ignore — leave state unchanged on failure
    }
  }

  return (
    <KeyboardAvoidingView
      style={{ flex: 1, backgroundColor: colors.background }}
      behavior={Platform.OS === "ios" ? "padding" : undefined}
    >
      <Header
        title={contactNumber ? formatPhoneNumber(contactNumber) : "Unknown"}
        subtitle={activeNumber ? `via ${formatPhoneNumber(activeNumber.phone_number)}` : ""}
        onBack={() => navigation.goBack()}
        right={
          <View style={[styles.toggle, { borderColor: colors.border }]}>
            <ToggleButton
              label="Chat"
              active={view === "chat"}
              onPress={() => setView("chat")}
              colors={colors}
            />
            <ToggleButton
              label="Dialer"
              active={view === "dialer"}
              onPress={() => setView("dialer")}
              colors={colors}
            />
          </View>
        }
      />

      {view === "chat" ? (
        <>
          <FlatList
            ref={listRef}
            data={messages}
            keyExtractor={(item) => item.id}
            contentContainerStyle={styles.chatContent}
            onContentSizeChange={() => listRef.current?.scrollToEnd({ animated: false })}
            renderItem={({ item }) => (
              <View
                style={[
                  styles.bubble,
                  item.direction === "outbound"
                    ? { alignSelf: "flex-end", backgroundColor: colors.accent }
                    : { alignSelf: "flex-start", backgroundColor: colors.surfaceAlt },
                ]}
              >
                <Text
                  style={[
                    typography.body,
                    { color: item.direction === "outbound" ? "#fff" : colors.textPrimary },
                  ]}
                >
                  {item.body}
                </Text>
              </View>
            )}
          />

          <View style={[styles.composer, { borderTopColor: colors.border }]}>
            <Pressable style={styles.iconButton} hitSlop={8}>
              <Text style={{ fontSize: 18, color: colors.textMuted }}>+</Text>
            </Pressable>
            <TextInput
              value={draft}
              onChangeText={setDraft}
              placeholder="Message"
              placeholderTextColor={colors.textMuted}
              multiline
              style={[
                typography.body,
                styles.composerInput,
                { backgroundColor: colors.surfaceAlt, color: colors.textPrimary },
              ]}
            />
            <Pressable
              onPress={handleSend}
              disabled={sending || !draft.trim()}
              style={[
                styles.sendButton,
                { backgroundColor: colors.accent, opacity: draft.trim() ? 1 : 0.5 },
              ]}
            >
              <Text style={{ color: "#fff", fontWeight: "700" }}>Send</Text>
            </Pressable>
          </View>
        </>
      ) : (
        <View style={styles.dialerWrap}>
          <Text style={[typography.h1, { color: colors.textPrimary, textAlign: "center" }]}>
            {formatPhoneNumber(dialedNumber) || " "}
          </Text>

          {callState === "active" ? (
            <Text style={[typography.body, { color: colors.textSecondary, textAlign: "center", marginTop: spacing.xs }]}>
              {formatCallDuration(callSeconds)}
            </Text>
          ) : null}

          <View style={styles.keypad}>
            {DIAL_KEYS.map((row, i) => (
              <View key={i} style={styles.keypadRow}>
                {row.map((key) => (
                  <Pressable
                    key={key}
                    onPress={() => handleDialPress(key)}
                    style={[styles.key, { backgroundColor: colors.surfaceAlt }]}
                  >
                    <Text style={[typography.h2, { color: colors.textPrimary }]}>{key}</Text>
                  </Pressable>
                ))}
              </View>
            ))}
          </View>

          {callState === "idle" ? (
            <View style={styles.callActionRow}>
              <Pressable onPress={handleBackspace} style={styles.sideButton}>
                <Text style={[typography.body, { color: colors.textMuted }]}>⌫</Text>
              </Pressable>
              <Pressable
                onPress={handleCallPress}
                style={[styles.callButton, { backgroundColor: colors.success }]}
              >
                <Text style={styles.callButtonText}>Call</Text>
              </Pressable>
              <View style={styles.sideButton} />
            </View>
          ) : (
            <View style={styles.inCallRow}>
              <Pressable
                onPress={handleToggleMute}
                style={[styles.pillButton, { backgroundColor: muted ? colors.accent : colors.surfaceAlt }]}
              >
                <Text style={[typography.caption, { color: muted ? "#fff" : colors.textPrimary }]}>
                  Mute
                </Text>
              </Pressable>
              <Pressable
                onPress={handleEndCall}
                style={[styles.callButton, { backgroundColor: colors.danger }]}
              >
                <Text style={styles.callButtonText}>End</Text>
              </Pressable>
              <Pressable
                onPress={() => setSpeaker((s) => !s)}
                style={[styles.pillButton, { backgroundColor: speaker ? colors.accent : colors.surfaceAlt }]}
              >
                <Text style={[typography.caption, { color: speaker ? "#fff" : colors.textPrimary }]}>
                  Speaker
                </Text>
              </Pressable>
            </View>
          )}
        </View>
      )}
    </KeyboardAvoidingView>
  );
}

function ToggleButton({ label, active, onPress, colors }) {
  return (
    <Pressable
      onPress={onPress}
      style={[styles.toggleButton, active && { backgroundColor: colors.accent }]}
    >
      <Text
        style={[
          typography.caption,
          { color: active ? "#fff" : colors.textSecondary, fontWeight: "600" },
        ]}
      >
        {label}
      </Text>
    </Pressable>
  );
}

const styles = StyleSheet.create({
  toggle: {
    flexDirection: "row",
    borderWidth: StyleSheet.hairlineWidth,
    borderRadius: radius.pill,
    padding: 2,
  },
  toggleButton: {
    paddingHorizontal: spacing.sm,
    paddingVertical: 6,
    borderRadius: radius.pill,
  },
  chatContent: {
    paddingHorizontal: spacing.lg,
    paddingBottom: spacing.md,
  },
  bubble: {
    maxWidth: "78%",
    paddingHorizontal: spacing.md,
    paddingVertical: 10,
    borderRadius: radius.lg,
    marginBottom: spacing.sm,
  },
  composer: {
    flexDirection: "row",
    alignItems: "flex-end",
    paddingHorizontal: spacing.lg,
    paddingVertical: spacing.sm,
    borderTopWidth: StyleSheet.hairlineWidth,
  },
  iconButton: {
    width: 32,
    height: 40,
    alignItems: "center",
    justifyContent: "center",
  },
  composerInput: {
    flex: 1,
    borderRadius: radius.lg,
    paddingHorizontal: spacing.md,
    paddingVertical: 10,
    maxHeight: 100,
  },
  sendButton: {
    marginLeft: spacing.sm,
    paddingHorizontal: spacing.md,
    paddingVertical: 10,
    borderRadius: radius.lg,
  },
  dialerWrap: {
    flex: 1,
    paddingHorizontal: spacing.lg,
    paddingTop: spacing.xl,
  },
  keypad: {
    marginTop: spacing.xl,
  },
  keypadRow: {
    flexDirection: "row",
    justifyContent: "space-between",
    marginBottom: spacing.md,
  },
  key: {
    width: 72,
    height: 72,
    borderRadius: 36,
    alignItems: "center",
    justifyContent: "center",
  },
  callActionRow: {
    flexDirection: "row",
    alignItems: "center",
    justifyContent: "space-between",
    marginTop: spacing.xl,
    paddingHorizontal: spacing.md,
  },
  inCallRow: {
    flexDirection: "row",
    alignItems: "center",
    justifyContent: "space-between",
    marginTop: spacing.xl,
    paddingHorizontal: spacing.sm,
  },
  sideButton: {
    width: 56,
    alignItems: "center",
  },
  callButton: {
    width: 72,
    height: 72,
    borderRadius: 36,
    alignItems: "center",
    justifyContent: "center",
  },
  callButtonText: {
    color: "#fff",
    fontWeight: "700",
  },
  pillButton: {
    paddingHorizontal: spacing.md,
    paddingVertical: spacing.sm,
    borderRadius: radius.pill,
  },
});
